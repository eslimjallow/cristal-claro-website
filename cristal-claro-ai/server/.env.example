PORT=4000
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Optional — leave empty to use ./data/*.json
# MONGODB_URI=mongodb+srv://user:pass@cluster/dbname

# Required for admin routes (/leads, /bookings, /analytics)
ADMIN_API_TOKEN=change-me-to-a-long-random-string

# Comma-separated origins for CORS (your Vercel URL + local dev)
CLIENT_ORIGIN=http://localhost:5173

# Reference only — WhatsApp links are built on the client with VITE_WHATSAPP_NUMBER
WHATSAPP_NUMBER=34612345678
